{
  "manifest_version": 3,
  "name": "Grade Entry Helper",
  "version": "1.1",
  "description": "Fill grade entries from clipboard data copied from Google Sheets",
  "permissions": [
    "clipboardRead",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://sgs.bopp-obec.info/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sgs.bopp-obec.info/sgs/TblTranscripts/Edit-TblTranscripts-Table.aspx*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_end"
    }
  ]
}