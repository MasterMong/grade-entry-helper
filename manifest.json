{
  "manifest_version": 3,
  "name": "Grade Entry Helper",
  "version": "2.0.0",
  "description": "Multi-page browser extension for streamlined grade entry and management in SGS system",
  "permissions": [
    "clipboardRead",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://sgs.bopp-obec.info/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sgs.bopp-obec.info/sgs/TblTranscripts/Edit-TblTranscripts-Table.aspx*"
      ],
      "js": [
        "src/content-scripts/grade-entry.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/shared/constants/*.js",
        "src/shared/ui/*.js", 
        "src/shared/utils/*.js",
        "src/core/*.js",
        "src/pages/gradeEntry/*.js"
      ],
      "matches": [
        "https://sgs.bopp-obec.info/*"
      ]
    }
  ]
}