{
  "manifest_version": 3,
  "name": "Grade Entry Helper",
  "version": "2.0.0",
  "description": "Multi-page browser extension for streamlined grade entry and management in SGS system",
  "permissions": [
    "clipboardRead",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://sgs.bopp-obec.info/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sgs.bopp-obec.info/sgs/TblTranscripts/Edit-TblTranscripts-Table.aspx*"
      ],
      "js": [
        "src/content-scripts/grade-entry.js"
      ],
      "run_at": "document_end"
    }
  ]
}