{
  "name": "grade-entry-helper",
  "version": "2.2.0",
  "description": "Browser extension for streamlined grade entry in SGS system",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "build:dev": "node scripts/build.js --dev",
    "build:watch": "node scripts/build.js --watch",
    "build:deploy": "npm run build && npm run package",
    "clean": "node scripts/clean.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "validate": "node scripts/validate.js",
    "package": "node scripts/package.js"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-terser": "^0.4.4",
    "chokidar": "^3.6.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "rollup": "^4.48.0",
    "sharp": "^0.34.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/grade-entry-helper.git"
  },
  "keywords": [
    "browser-extension",
    "grade-entry",
    "education",
    "sgs",
    "chrome-extension",
    "firefox-addon"
  ],
  "author": "Your Name",
  "license": "MIT",
  "browserslist": [
    "Chrome >= 88",
    "Firefox >= 78",
    "Edge >= 88"
  ]
}
